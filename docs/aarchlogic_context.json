{
  "project": {
    "name": "AarchLogic",
    "version": "1.0.0",
    "tagline": "Universal Bit-Sliced Logic Synthesis Engine for ARM64",
    "description": "Production-grade bit-sliced logic engine delivering 1.3B+ TPS with sub-microsecond deterministic latency",
    "homepage": "https://github.com/yourusername/aarchlogic",
    "license": "Business Source License 1.1 (until 2029-05-03, then Apache 2.0)",
    "author": "Suprath PS",
    "year": "2024-2026"
  },

  "performance_targets": {
    "throughput_tps": 1342049089,
    "throughput_description": "1.3 Billion transactions per second on ARM64 Linux (4 threads)",
    "latency_ns": 100,
    "latency_description": "Deterministic ~100 nanoseconds per 64-row batch",
    "memory_fixed": true,
    "memory_fixed_description": "No dynamic allocation in hot paths, predictable footprint",
    "deterministic": true,
    "deterministic_description": "Platform-independent results via fixed-point arithmetic"
  },

  "core_modules": {
    "registry": {
      "name": "Module 1: Metadata Registry",
      "responsibility": "Field descriptor management, schema definitions, FlatBuffers integration",
      "hot_path": false,
      "latency_budget_ns": 0,
      "key_classes": ["FieldDescriptor", "Schema", "Registry"],
      "constraints": ["Compile-time execution", "No allocation during schema registration"]
    },
    "memory_fabric": {
      "name": "Module 2: Memory Fabric",
      "responsibility": "Fixed-size arena allocators, zero-copy IPC (iceoryx), wait-free subscribers",
      "hot_path": false,
      "latency_budget_ns": 0,
      "key_classes": ["Arena", "MemoryPool", "Subscriber"],
      "constraints": ["No heap allocation", "Wait-free access"]
    },
    "bit_slicer": {
      "name": "Module 3: Bit-Slicer",
      "responsibility": "64×64 bit-matrix transpose (6-stage Knuth), Google Highway SIMD dispatcher",
      "hot_path": true,
      "latency_budget_ns": 80,
      "key_functions": ["BitSlicer::slice", "Transpose64x64", "Stage5..Stage0"],
      "algorithm": "Knuth 6-stage bit-slicing transpose",
      "simd_library": "Google Highway",
      "constraints": ["Zero heap", "Branchless SIMD", "Cache-line aligned buffers (64 bytes)"]
    },
    "jit_kernel": {
      "name": "Module 4: JIT Comparison Kernel",
      "responsibility": "ARM64 native code generation (AsmJit), unrolled bit-plane comparison",
      "hot_path": true,
      "latency_budget_ns": 20,
      "key_classes": ["JitCompiler", "KernelFunc"],
      "target_isa": "ARM64 (AArch64)",
      "fallback_isa": ["x86_64", "MIPS64"],
      "constraints": ["No branches in kernel", "Post-index addressing for pipelining", "64 unrolled iterations"]
    },
    "orchestrator": {
      "name": "Module 5: High-Throughput Orchestrator",
      "responsibility": "Work-stealing thread pool, batch scheduling, result aggregation",
      "hot_path": true,
      "latency_budget_ns": 100,
      "key_classes": ["Orchestrator", "WorkStealingQueue"],
      "batch_size": 64,
      "max_threads": 32,
      "constraints": ["Per-thread local accumulation", "No false sharing", "64-byte aligned counters"]
    }
  },

  "api_contract": {
    "c_api": {
      "language": "C",
      "header": "apex/apex_c_api.h",
      "opaque_types": [
        "apex_engine_h"
      ],
      "enumerations": {
        "execution_modes": {
          "APEX_EXEC_MODE_BIT_SLICED": 0,
          "APEX_EXEC_MODE_SCALAR": 1
        },
        "data_types": {
          "APEX_UINT8": 0,
          "APEX_UINT16": 1,
          "APEX_UINT32": 2,
          "APEX_UINT64": 3,
          "APEX_INT8": 4,
          "APEX_INT16": 5,
          "APEX_INT32": 6,
          "APEX_INT64": 7
        },
        "error_codes": {
          "APEX_OK": 0,
          "APEX_ERR_INVALID_ARG": 1,
          "APEX_ERR_NOT_FOUND": 2,
          "APEX_ERR_ALLOC": 3,
          "APEX_ERR_COMPILE": 4,
          "APEX_ERR_EXEC": 5,
          "APEX_ERR_INVALID_MODE": 6
        }
      },
      "structures": {
        "apex_field_descriptor_t": {
          "fields": {
            "name": "const char*",
            "offset": "size_t",
            "bit_width": "size_t",
            "data_type": "int"
          },
          "notes": "Used with apex_register_schema()"
        }
      },
      "functions": {
        "apex_create": {
          "signature": "apex_engine_h apex_create(void)",
          "returns": "Engine handle or NULL",
          "notes": "Initializes engine, may trigger JIT warm-up"
        },
        "apex_destroy": {
          "signature": "void apex_destroy(apex_engine_h)",
          "returns": "void",
          "notes": "Safe to call multiple times"
        },
        "apex_register_schema": {
          "signature": "int apex_register_schema(apex_engine_h, const char*, const apex_field_descriptor_t*, size_t, size_t)",
          "returns": "0 on success, non-zero on error",
          "max_fields": 256,
          "notes": "Must call before apex_set_logic"
        },
        "apex_set_logic": {
          "signature": "int apex_set_logic(apex_engine_h, const char*, void*, int)",
          "returns": "0 on success, non-zero on error",
          "notes": "Triggers JIT compilation; IR pointer can be freed after call"
        },
        "apex_execute": {
          "signature": "uint64_t apex_execute(apex_engine_h, const void*, size_t)",
          "returns": "Match count on success, (uint64_t)-1 on error",
          "throughput_tps": 1342049089,
          "latency_per_batch_ns": 100,
          "notes": "No allocation, deterministic execution"
        }
      }
    },
    "cpp_api": {
      "language": "C++",
      "header": "apex/AarchGate.hpp",
      "namespace": "apex",
      "classes": {
        "Apex": {
          "methods": {
            "constructor": "Apex()",
            "destructor": "~Apex()",
            "register_schema": "void register_schema(const std::string&, const std::vector<apex_field_descriptor_t>&, size_t)",
            "set_logic": "void set_logic(const std::string&, void*, int)",
            "execute": "uint64_t execute(const void*, size_t)"
          },
          "exceptions": "Throws std::runtime_error on failure",
          "copy_semantics": "Deleted (move-only)"
        }
      }
    },
    "python_api": {
      "language": "Python 3.8+",
      "module": "aarchgate_python",
      "classes": {
        "AarchGateEngine": {
          "methods": {
            "__init__": "Create engine instance",
            "register_schema": "Register schema with field list",
            "set_logic": "Set expression logic",
            "execute": "Execute and return match count"
          },
          "exceptions": "Raises Exception on errors"
        },
        "Field": {
          "constructor": "Field(name: str, offset: int, bit_width: int, data_type: int)"
        }
      },
      "constants": {
        "BIT_SLICED": 0,
        "SCALAR": 1,
        "UINT8": 0,
        "UINT16": 1,
        "UINT32": 2,
        "UINT64": 3
      }
    },
    "java_api": {
      "language": "Java 11+",
      "package": "com.aarchgate.engine",
      "classes": {
        "AarchGateEngine": {
          "methods": {
            "AarchGateEngine": "Constructor",
            "registerSchema": "void registerSchema(String, Field[], int)",
            "setLogic": "void setLogic(String, long, int)",
            "execute": "long execute(ByteBuffer, long)"
          },
          "exceptions": "Throws AarchGateException"
        },
        "Field": {
          "fields": ["String name", "int offset", "int bitWidth", "DataType dataType"]
        },
        "DataType": {
          "enum_values": ["UINT8", "UINT16", "UINT32", "UINT64", "INT8", "INT16", "INT32", "INT64"]
        },
        "ExecutionMode": {
          "enum_values": ["BIT_SLICED", "SCALAR"]
        }
      }
    }
  },

  "ultra_low_latency_constraints": {
    "zero_heap": {
      "rule": "No dynamic allocation in hot paths",
      "applies_to": ["BitSlicer", "JitKernel", "Orchestrator"],
      "enforcement": "Static allocation, arena allocators, thread-local storage",
      "cost_of_violation": "10-100× latency increase due to malloc contention"
    },
    "branchless": {
      "rule": "Use bitwise logic and conditional moves instead of branches",
      "applies_to": ["JitKernel", "BitSlicer"],
      "enforcement": "AsmJit code generation, SIMD bit operations",
      "cost_of_violation": "Pipeline flush on misprediction, 10-20 cycle penalty"
    },
    "cache_first": {
      "rule": "Align hot data to 64-byte cache lines",
      "applies_to": ["ColumnBuffer", "Registry", "Counter"],
      "enforcement": "alignas(64) C++ qualifier",
      "cost_of_violation": "False sharing, 10-50× latency increase"
    },
    "fixed_point": {
      "rule": "Use int64_t; no floating-point in hot paths",
      "applies_to": ["JitKernel", "BitSlicer", "Comparison"],
      "enforcement": "Type system, ULL audit",
      "cost_of_violation": "Platform-dependent results, IEEE-754 variability"
    }
  },

  "memory_constraints": {
    "alignment": {
      "cache_line": 64,
      "page": 4096,
      "hugepage": 2097152,
      "notes": "All hot structures must be 64-byte aligned"
    },
    "fixed_footprint": {
      "column_buffer": 512,
      "column_buffer_description": "64 uint64_t × 8 bytes",
      "per_thread": 8192,
      "per_thread_description": "Column buffer + local accumulator",
      "jit_cache": 10485760,
      "jit_cache_description": "~10MB for compiled kernels (1000 expressions)"
    },
    "batch_size": {
      "rows": 64,
      "bytes": 512,
      "reasoning": "Matches bit-matrix dimensions and cache-line alignment"
    }
  },

  "execution_modes": {
    "bit_sliced": {
      "mode_id": 0,
      "throughput_tps": 1342049089,
      "latency_per_batch_ns": 100,
      "batch_size": 64,
      "memory_working_set": 512,
      "use_cases": ["High-volume queries", "Complex expressions", "Batch processing"],
      "algorithm": "Transpose + JIT kernel + parallel execution",
      "scaling": "Linear with thread count"
    },
    "scalar": {
      "mode_id": 1,
      "throughput_tps": 4000000,
      "latency_per_row_us": 30,
      "batch_size": 1,
      "memory_working_set": 0,
      "use_cases": ["Single-row evaluation", "Ultra-low latency requirement"],
      "algorithm": "Naive C++ comparison loop",
      "scaling": "Does not scale with thread count"
    }
  },

  "data_layout": {
    "input_format": {
      "name": "Array-of-Structs (AoS)",
      "description": "Row-major: [Row0][Row1]...[RowN]",
      "example": "uint8_t data[num_rows * stride]"
    },
    "internal_format": {
      "name": "Bit-Planes (Column-Major, Transposed)",
      "description": "64×64 bit-matrix: bitplane[i] = bits i of all 64 rows",
      "example": "uint64_t bitplanes[64]"
    },
    "transformation": {
      "algorithm": "6-stage Knuth transpose",
      "latency_ns": 80,
      "stages": 6,
      "stage_details": [
        "Stage 5: Swap bits at distance 32 (SIMD × 32 lanes)",
        "Stage 4: Swap bits at distance 16 (SIMD × 16 lanes)",
        "Stage 3: Swap bits at distance 8 (SIMD × 8 lanes)",
        "Stage 2: Swap bits at distance 4 (SIMD × 4 lanes)",
        "Stage 1: Swap bits at distance 2 (SIMD × 2 lanes)",
        "Stage 0: Swap bits at distance 1 (scalar loop)"
      ]
    }
  },

  "jit_code_generation": {
    "target_isa": "ARM64 (AArch64)",
    "backend_library": "AsmJit",
    "code_size": 996,
    "code_size_description": "~996 bytes for 64-bit comparison kernel",
    "execution_latency_ns": 20,
    "execution_latency_description": "~20ns for full comparison",
    "register_allocation": {
      "x0": "input (bit_planes_ptr)",
      "x9": "GT accumulator",
      "x10": "EQ accumulator",
      "x11": "pointer walker",
      "x12": "loaded bit-plane",
      "x13": "scratch register"
    },
    "instruction_types": [
      "LDR (post-index addressing)",
      "AND, ORR, EOR (bitwise logic)",
      "MOV, ADD (setup)"
    ],
    "optimization_techniques": [
      "Unrolled 64 iterations",
      "Post-index addressing for pipelining",
      "No branches (branchless)",
      "Register pressure minimized"
    ]
  },

  "correctness_guarantees": {
    "bit_perfect_parity": true,
    "bit_perfect_parity_description": "Identical results to scalar C++ across all platforms",
    "platform_determinism": true,
    "platform_determinism_description": "Fixed-point arithmetic ensures identical results on x86, ARM, MIPS, RISC-V",
    "verification_method": "128M row benchmark with bit-level spot-check",
    "verification_results": {
      "scalar_matches": 89588765,
      "parallel_matches": 89588765,
      "delta": 0,
      "spot_check_first_64": "100% pass",
      "spot_check_last_64": "100% pass"
    }
  },

  "deployment_scenarios": {
    "docker": {
      "image": "aarchlogic:latest",
      "dockerfile": ".docker/build.Dockerfile",
      "base_image": "ubuntu:22.04",
      "target_platform": "linux/arm64",
      "features": ["Pre-built", "Reproducible", "Zero-configuration"]
    },
    "native_linux": {
      "artifacts": ["libaarchgate.so", "include/apex/"],
      "library_path": "/usr/local/lib",
      "header_path": "/usr/local/include",
      "pkg_config": "aarchlogic.pc"
    },
    "embedded": {
      "minimum_ram": "4GB",
      "minimum_cpu": "ARM Cortex-A72+",
      "no_external_dependencies": true,
      "static_linking": "Supported via CMake"
    }
  },

  "performance_tuning": {
    "cpu_affinity": {
      "recommendation": "Pin threads to isolated CPU cores",
      "tool": "taskset -c 2-3 ./app",
      "benefit": "Eliminates scheduler interference"
    },
    "huge_pages": {
      "recommendation": "Enable 2MB or 1GB huge pages",
      "command": "echo 1024 > /proc/sys/vm/nr_hugepages",
      "benefit": "10-20% throughput improvement (fewer TLB misses)"
    },
    "frequency_scaling": {
      "recommendation": "Disable frequency scaling, set performance mode",
      "command": "echo performance | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor",
      "benefit": "Predictable latency, no frequency ramp-up"
    },
    "numa_awareness": {
      "tool": "numactl --cpunodebind=0 --membind=0 ./app",
      "benefit": "Reduced cross-socket traffic on NUMA systems"
    }
  },

  "supported_platforms": {
    "primary": {
      "os": "Linux",
      "architecture": "ARM64 (AArch64)",
      "compiler": "Clang 15+ or GCC 10+",
      "status": "Production-verified"
    },
    "secondary": {
      "os": "Linux",
      "architecture": "x86_64",
      "compiler": "Clang 15+",
      "status": "Functional (fallback ISA)",
      "notes": "Uses generic SIMD, not x86-specific optimizations"
    },
    "experimental": [
      "macOS (ARM64) via Docker",
      "Windows via WSL2"
    ]
  },

  "language_bindings": {
    "c": {
      "stable": true,
      "header": "apex/apex_c_api.h",
      "use_for": "System integration, embedded systems"
    },
    "cpp": {
      "stable": true,
      "header": "apex/AarchGate.hpp",
      "use_for": "Native applications, RAII semantics"
    },
    "python": {
      "stable": true,
      "module": "aarchgate_python",
      "backend": "pybind11",
      "use_for": "Data science, NumPy integration"
    },
    "java": {
      "stable": true,
      "package": "com.aarchgate.engine",
      "backend": "JNI",
      "use_for": "JVM applications, enterprise systems"
    }
  },

  "build_system": {
    "primary_build_tool": "CMake 3.18+",
    "generator": "Ninja (recommended) or Unix Makefiles",
    "c++_standard": "C++20",
    "external_dependencies": {
      "asmjit": "JIT code generation (optional, graceful fallback)",
      "highway": "Portable SIMD (optional, scalar fallback)",
      "iceoryx": "Zero-copy IPC (optional, single-process fallback)",
      "flatbuffers": "Schema serialization (optional, manual serialization fallback)"
    },
    "build_flags": {
      "release": "-O3 -march=native -ffast-math -fno-finite-math-only",
      "debug": "-O0 -g -fsanitize=address,undefined -fno-omit-frame-pointer"
    }
  },

