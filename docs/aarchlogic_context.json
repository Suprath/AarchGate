    "unit_tests": {
      "test_registry": "Schema registration correctness",
      "test_bit_slicer_transpose": "Bit-matrix transpose verification",
      "test_memory_fabric": "Memory pool allocation and access",
      "test_universal_cxx": "End-to-end C++ API test"
    },
    "benchmarks": {
      "bench_bit_slicer": "Transpose latency microbenchmark",
      "bench_aarchgate_final": "Full 128M row benchmark with verification",
      "bench_10b_rps": "Trading workload throughput test"
    },
    "verification": {
      "scalar_baseline": "Single-threaded scalar comparison (correctness check)",
      "bit_level_spot_check": "Bit-by-bit verification of first/last chunks",
      "match_count_comparison": "Delta verification between modes"
